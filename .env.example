# ── Required at deploy time ───────────────────────────────────────────────────
#
# docling-service is behind an IP allowlist. This orchestrator must reach it
# through an HTTP proxy. Supply the full proxy URL — including credentials if
# required — via this variable.
#
# Format: http://user:pass@proxyhost:port
#
# NEVER commit a real value here or paste it into a ticket, prompt, or chat log.
# Obtain the actual value out-of-band (direct communication or your team's
# secrets manager) and inject it into the deployment environment.
#
DOCLING_PROXY_URL=http://user:pass@proxyhost:port

# ── Optional overrides (defaults shown) ──────────────────────────────────────
DOCLING_SERVICE_URL=http://129.212.178.134:8001
DOCLING_ENDPOINT=/convert-gpu
DOCLING_OCR_MODE=auto
DOCLING_TABLE_MODE=accurate

# VLM server (vLLM, OpenAI-compatible API)
VLM_BASE_URL=http://localhost:8000
VLM_MODEL=your-model-name-here

# Pipeline tuning
PAGE_ROUTING_TOP_N=5
REQUEST_TIMEOUT_SECONDS=45
MAX_FILE_SIZE_MB=50

# API key allowlist — comma-separated. Placeholder only; see README security note.
VALID_API_KEYS=eb3-key-1,eb3-key-2
